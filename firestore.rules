rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isRecruiter() {
      return request.auth != null &&
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.userType == 'recruiter';
    }

    // Resumes collection - one resume per document.
    // Users manage their own resumes; recruiters can read individual resume docs
    // for candidate ranking/application review.
    match /Resumes/{resumeId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (isRecruiter() && resource.data.keys().hasAll(['id', 'content']))
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Users collection - users can read/write their own profile
    match /Users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public login-page presence count. Documents contain only ephemeral
    // session IDs and timestamps so the login screen can show active viewers.
    match /LoginPageViewers/{viewerId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly([
          'sessionId',
          'page',
          'lastSeenAt',
          'createdAt'
        ]) &&
        request.resource.data.sessionId == viewerId &&
        request.resource.data.page == 'candidate-login' &&
        request.resource.data.lastSeenAt == request.time &&
        request.resource.data.createdAt == request.time;
      allow delete: if resource.data.sessionId == viewerId;
    }
    
    // JobOpportunities collection
    match /JobOpportunities/{jobId} {
      // Anyone can read active job opportunities
      allow read: if request.auth != null && resource.data.isActive == true;
      // Recruiters can create their own job opportunities
      allow create: if request.auth != null && request.resource.data.recruiterId == request.auth.uid;
      // Only the recruiter who created it can update/delete
      allow update, delete: if request.auth != null && resource.data.recruiterId == request.auth.uid;
    }

    // JobApplications - candidates apply for jobs; recruiters read applications for their jobs
    match /JobApplications/{applicationId} {
      allow create: if request.auth != null && request.resource.data.candidateId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.candidateId == request.auth.uid ||
        get(/databases/$(database)/documents/JobOpportunities/$(resource.data.jobId)).data.recruiterId == request.auth.uid
      );
      allow update, delete: if false;
    }

    // ResumeByRole: resumes indexed by role doc (e.g. ResumeByRole/frontend/resumes/{resumeId})
    // Candidates write their own lightweight index docs; recruiters can read all
    // index docs and fetch the source resume document by resumeId when needed.
    match /ResumeByRole/{roleId}/resumes/{resumeId} {
      allow read: if isRecruiter();
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
